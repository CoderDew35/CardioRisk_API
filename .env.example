# ─── Application ──────────────────────────────────────────────
APP_ENV=development
APP_NAME=CardioRiskAPI
LOG_LEVEL=INFO

# ─── PostgreSQL ───────────────────────────────────────────────
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=cardiorisk
POSTGRES_USER=cardiorisk_user
POSTGRES_PASSWORD=cardiorisk_pass
DATABASE_URL=postgresql+asyncpg://cardiorisk_user:cardiorisk_pass@localhost:5432/cardiorisk

# ─── RabbitMQ ─────────────────────────────────────────────────
RABBITMQ_HOST=localhost
RABBITMQ_PORT=5672
RABBITMQ_USER=guest
RABBITMQ_PASSWORD=guest
RABBITMQ_VHOST=/
RABBITMQ_URL=amqp://guest:guest@localhost:5672/

# ─── MinIO (Delta Lake storage) ───────────────────────────────
MINIO_ENDPOINT=http://localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=cardiorisk
DELTA_LAKE_PATH=./data/lakehouse

# ─── OpenRouter (LLM) ─────────────────────────────────────────
OPENROUTER_API_KEY=123
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_MODEL=openai/gpt-4o
OPENROUTER_MAX_TOKENS=300
OPENROUTER_TEMPERATURE=0.3

# ─── ML Models ────────────────────────────────────────────────
MODEL_PATH=ml/models/lgbm_cardio_v1.joblib
SHAP_EXPLAINER_PATH=ml/models/shap_explainer_v1.joblib
MODEL_THRESHOLD=0.5

# ─── MLflow ───────────────────────────────────────────────────
MLFLOW_TRACKING_URI=http://localhost:5000
MLFLOW_EXPERIMENT_NAME=cardiorisk-lgbm

# ─── Dataset ──────────────────────────────────────────────────
DATASET_CSV_PATH=ml/data/cardio_dataset.csv
